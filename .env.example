# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ragdb
# Use "postgres" when running via Docker Compose; "localhost" for local dev outside Docker
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Gemini (LLM + Embeddings — single key covers both endpoints) ─────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ─── Tavily (web search) ──────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=info

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Backend URL as seen from the Next.js server (Node.js process, not the browser).
# Local dev: http://localhost:8000
# Docker Compose: overridden to http://backend:8000 via docker-compose.yml environment block
BACKEND_URL=http://localhost:8000

# Backend URL as seen from the browser — used for any direct browser→API calls
NEXT_PUBLIC_API_URL=http://localhost:8000
