# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ragdb
# Use "postgres" when running via Docker Compose; "localhost" for local dev outside Docker
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Gemini (LLM + Embeddings — single key covers both endpoints) ─────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ─── Fernet (symmetric encryption for data_sources connection_config) ────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=your-fernet-key-here

# ─── Tavily (web search) ──────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Email (Resend — https://resend.com) ──────────────────────────────────────
# Free tier API key from resend.com dashboard
RESEND_API_KEY=re_your_resend_api_key_here
# Sender address — must be a verified domain (or use onboarding@resend.dev for testing)
EMAIL_FROM=onboarding@resend.dev
# Set to false in local dev to skip email verification (users verified immediately on signup)
# Set to true in production to require email verification before login
REQUIRE_EMAIL_VERIFICATION=true

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=info
# Public URL of the frontend — used in email links (verification, password reset)
# Local dev via Docker: http://localhost  (port 80, nginx)
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Backend URL as seen from the Next.js server (Node.js process, not the browser).
# Local dev: http://localhost:8000
# Docker Compose: overridden to http://backend:8000 via docker-compose.yml environment block
BACKEND_URL=http://localhost:8000

# Backend URL as seen from the browser — used for any direct browser→API calls
NEXT_PUBLIC_API_URL=http://localhost:8000
